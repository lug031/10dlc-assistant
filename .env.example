# =====================================================================
# API (apps/api)
# =====================================================================
# Entorno: "development" (local) o "production" (deploy)
NODE_ENV=development

# Puerto del API. En Render se inyecta automáticamente, no lo fuerces allí.
PORT=3001

# Host de escucha.
#  - Local: 127.0.0.1
#  - Producción (Render/Railway/Fly): 0.0.0.0
HOST=127.0.0.1

# --- Base de datos (libSQL / Turso) ---------------------------------
# Local (archivo SQLite): déjalo vacío y se usará ./apps/api/data/10dlc.db,
# o especifica una ruta con DATABASE_PATH.
#
# Producción (Turso): pega la URL libsql:// y el token de tu base.
#   DATABASE_URL=libsql://<tu-db>-<org>.turso.io
#   DATABASE_AUTH_TOKEN=<token-generado-por-turso>
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Alternativa local por ruta de archivo (se ignora si DATABASE_URL está seteado)
DATABASE_PATH=./apps/api/data/10dlc.db

# Orígenes permitidos por CORS (dominios del frontend), separados por coma.
#  - Local: se usa localhost:5173 por defecto si se deja vacío.
#  - Producción: la URL pública del frontend, p. ej. https://tu-app.vercel.app
CORS_ORIGIN=

# =====================================================================
# Web (apps/web · Vite)
# =====================================================================
# URL pública del API (sin /api al final; el cliente ya lo agrega).
#  - Local: http://127.0.0.1:3001
#  - Producción: https://tu-api.onrender.com
VITE_API_URL=http://127.0.0.1:3001
